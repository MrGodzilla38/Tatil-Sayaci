<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/cards_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/summer_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/notification_card_summer"
            android:padding="10dp"
            android:layout_marginEnd="6dp"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/summer_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☀️"
                android:textSize="18sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/summer_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yaz"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/summer_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="37g"
                android:textSize="11sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/holiday_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/notification_card_holiday"
            android:padding="10dp"
            android:layout_marginEnd="6dp"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/holiday_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎉"
                android:textSize="18sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/holiday_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kurban Bayra.."
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/holiday_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="6g"
                android:textSize="11sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/custom_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/notification_card_custom"
            android:padding="10dp"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/custom_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐"
                android:textSize="18sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/custom_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Deneme"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/custom_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="9g"
                android:textSize="11sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/empty_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Şu an yaklaşan tatil yok"
        android:textSize="13sp"
        android:textColor="#666666"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone" />

</LinearLayout>
